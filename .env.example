# Root orchestration env — template for .env
# Only variables consumed at the docker-compose level belong here.
# Service-specific config goes in backend/.env and engine/.env.docker.

# PostgreSQL container initialization (used ONLY by the db service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=elearning

# Frontend → Backend public URL (injected into the Vite build at runtime)
VITE_API_URL=http://localhost:5000/api
