# Database Configuration
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=elearning

# Backend Secrets
JWT_SECRET=your_jwt_secret_here
SESSION_SECRET=your_session_secret_here

# Ollama (engine embeddings + health check; Docker service name ollama)
OLLAMA_BASE_URL=http://ollama:11434
# Optional full URL override (defaults to ${OLLAMA_BASE_URL}/api/embeddings)
# OLLAMA_EMBEDDINGS_URL=http://ollama:11434/api/embeddings
OLLAMA_MODEL=nomic-embed-text

# Service URLs (Docker service names)
ENGINE_URL=http://engine:8000
FRONTEND_URL=http://frontend:3000

# OAuth (Google)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# OAuth (GitHub)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=your_email@gmail.com

# Environment
NODE_ENV=development
PORT=5000

# Frontend (Vite)
VITE_API_URL=http://backend:5000/api

# PostgreSQL (for db service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=elearning
POSTGRES_PORT=5432