# Backend service environment — template for backend/.env

# Server
PORT=5000
NODE_ENV=docker

# Database — single source of truth.
# Local Docker: point to the db container (service name resolves inside Docker network).
# Staging (Neon): injected via docker-compose.staging.yml; do not set here for staging.
# Outside Docker (local dev): set DATABASE_URL_EXTERNAL to a localhost:5432 URL instead.
DATABASE_URL=postgresql://postgres:change_me_postgres_password@db:5432/elearning

# Required: auth + engine integration
JWT_SECRET=change_me_jwt_secret
ENGINE_URL=http://engine:8000
FRONTEND_URL=http://localhost:3000
PDF_STORAGE_PATH=/app/data/uploads

# Optional: session hardening (recommended in production)
SESSION_SECRET=change_me_session_secret
BACKEND_URL=http://localhost:5000

# Optional OAuth integrations (leave empty to disable social login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional SMTP integration (leave empty to disable email reset flow)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
