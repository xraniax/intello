{
  "name": "@cognify/backend",
  "version": "1.0.0",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "npm run migrate && npm run start:server",
    "dev": "npm run migrate && npm run dev:server",
    "start:server": "node src/server.js",
    "dev:server": "nodemon src/server.js",
    "migrate": "node scripts/migrate.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "test": "NODE_OPTIONS='--experimental-vm-modules' npx jest",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' npx jest --coverage",
    "test:unit": "NODE_OPTIONS='--experimental-vm-modules' npx jest --testPathPattern=unit",
    "test:integration": "NODE_OPTIONS='--experimental-vm-modules' npx jest --testPathPattern=integration",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' npx jest --watch",
    "create:admin": "node scripts/createAdmin.js"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "ejs": "^4.0.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.0",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.0",
    "nodemailer": "^8.0.2",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": ""
}
