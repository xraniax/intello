# Engine local-dev environment — template for engine/.env
# Used when running the engine directly on a developer machine (not inside Docker).
# When running inside Docker, engine/.env.docker is used instead.

# Database — Docker db container exposed on localhost:5432.
# Switch to your Neon URL here for staging local runs.
DATABASE_URL=postgresql://postgres:change_me_postgres_password@localhost:5432/elearning

# Cache / queue — Docker Redis exposed on localhost
REDIS_URL=redis://localhost:6379

# Ollama — local daemon or Docker-exposed
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_GENERATION_MODEL=qwen2.5:3b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_NUM_GPU=0
OLLAMA_MAX_CONTEXT_CHARS=12000

# Uploads directory for local runs
COGNIFY_UPLOADS_DIR=../data/uploads

# Optional Google Drive integration (leave empty to disable Drive upload flow)
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_DRIVE_FOLDER_ID=
