# Engine Docker runtime environment (single source of truth for engine + celery_worker)

# Required: database connection (must match backend/db service values)
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_me_postgres_password
DB_NAME=elearning

# Cache / queue
REDIS_URL=redis://redis:6379

# Required Ollama settings
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_GENERATION_MODEL=qwen2.5:3b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# GPU/CPU selector hint for engine logic (1 enables GPU, 0 forces CPU)
OLLAMA_NUM_GPU=1
OLLAMA_MAX_CONTEXT_CHARS=12000
OLLAMA_REQUEST_RETRIES=4
OLLAMA_REQUEST_RETRY_DELAY_SECONDS=2
OLLAMA_STARTUP_RETRIES=5
OLLAMA_STARTUP_RETRY_DELAY_SECONDS=2

# Shared uploads mount inside containers
COGNIFY_UPLOADS_DIR=/app/data/uploads

# Optional Google Drive integration (leave empty to disable Drive upload flow)
# Preferred (production-safe): base64-encoded service account JSON
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
# Development-only fallback: local credentials file path
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_DRIVE_FOLDER_ID=
