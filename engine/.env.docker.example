# Engine Docker runtime environment — template for engine/.env.docker
# Used by engine and celery_worker containers.
# For staging, DATABASE_URL is injected by docker-compose.staging.yml — no edits needed here.

# Database — single source of truth for local Docker mode.
# Must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB in root .env.
DATABASE_URL=postgresql://postgres:change_me_postgres_password@db:5432/elearning

# Cache / queue
REDIS_URL=redis://redis:6379

# Ollama configuration
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_GENERATION_MODEL=qwen2.5:3b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_NUM_GPU=0
OLLAMA_MAX_CONTEXT_CHARS=12000
OLLAMA_REQUEST_RETRIES=4
OLLAMA_REQUEST_RETRY_DELAY_SECONDS=2
OLLAMA_STARTUP_RETRIES=5
OLLAMA_STARTUP_RETRY_DELAY_SECONDS=2

# Shared uploads mount (must match the volume mount in docker-compose.yml)
COGNIFY_UPLOADS_DIR=/app/data/uploads

# Optional Google Drive integration (leave empty to disable Drive upload flow)
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_DRIVE_FOLDER_ID=
